state-fuzzer-server

# SUT config
-connect
localhost:${sul.port}
-startWait
1000
-responseWait
200
-protocol
DTLS12
-cmd
modules/jdk-${jsse.version}/bin/java -jar suts/jsse-${jsse.version}-dtls-clientserver.jar -port ${sul.port} -hostname localhost -keyLocation ${keystore}/rsa2048.jks -keyPassword password -trustLocation ${keystore}/rsa2048.jks -trustPassword password -threadStarterIpPort localhost:${fuzzer.port} -operation FULL -auth NEEDED
-adapterPort
${fuzzer.port}
-processTrigger
START

# learning config
-alphabet
${alphabets.ra.servers}/jsse/ecdhe_cert.xml
-maxRuns
20000
-randLength
10
-learningAlgorithm
RaStar
-equivalenceAlgorithms
IO_RANDOM_WALK
-maxDepthRA
10
-probNewDataValue
0.5
-seed
7
-output
${output.ra}/jsse-${jsse.version}_server_ecdhe_cert_req
-skipNonDetTests
